# ============================================================
# 生产环境变量 — psyaihelp.xin 部署配置
# 使用方式: cp .env.production .env && docker compose up -d
# ============================================================

# 域名 & SSL
DOMAIN=psyaihelp.xin
EMAIL=3186551424@qq.com

# MySQL
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=mental_health_db

# JWT
JWT_SECRET=mental_health_jwt_secret_prod_key_min_32
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI
AI_MODEL_PROVIDER=deepseek
AI_MODEL_API_KEY=your_deepseek_api_key_here
AI_MODEL_NAME=deepseek-chat
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# CORS (生产环境域名)
ALLOWED_ORIGINS=https://psyaihelp.xin

# Rate Limit
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
DAILY_CHAT_LIMIT=50
