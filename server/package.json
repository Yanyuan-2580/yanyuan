    "@nestjs/jwt": "^10.0.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.0",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.0",
    "mongodb": "^6.0.0",
    "mongoose": "^7.8.9",
    "mysql2": "^3.6.0",
