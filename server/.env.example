NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=mental_health_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

MONGODB_URI=mongodb://localhost:27017/mental_health

JWT_SECRET=your_jwt_secret_min_32_characters_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

AI_MODEL_PROVIDER=deepseek
AI_MODEL_API_KEY=your_deepseek_api_key
AI_MODEL_NAME=deepseek-chat
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

OSS_ACCESS_KEY_ID=your_key
OSS_ACCESS_KEY_SECRET=your_secret
OSS_BUCKET=your_bucket
OSS_ENDPOINT=your_endpoint

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
DAILY_CHAT_LIMIT=50

SENTRY_DSN=your_sentry_dsn

# --- 通知服务配置 ---
# 短信服务商: aliyun | tencent | log (log=仅日志, 不发送)
SMS_PROVIDER=log
# 阿里云短信 (SMS_PROVIDER=aliyun 时生效)
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_secret
ALIYUN_SMS_SIGN_NAME=心理健康助手
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789
# 腾讯云短信 (SMS_PROVIDER=tencent 时生效)
TENCENT_SMS_APP_ID=your_tencent_app_id
TENCENT_SMS_SECRET_ID=your_tencent_secret_id
TENCENT_SMS_SECRET_KEY=your_tencent_secret_key
TENCENT_SMS_SIGN_NAME=心理健康助手
TENCENT_SMS_TEMPLATE_ID=1234567
# 邮件服务商: smtp | log
EMAIL_PROVIDER=log
# SMTP 邮件 (EMAIL_PROVIDER=smtp 时生效)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=心理健康助手
# 管理员告警接收
ADMIN_ALERT_PHONE=13800138000
ADMIN_ALERT_EMAIL=admin@example.com
